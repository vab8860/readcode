say "Tasks Demo"

task greet ...
  say "hello"
done

task calculate ...
  set x to 10 plus 5
  say "calculated" x
done

task show_result ...
  say "done"
done

do greet
do calculate
do show_result

task greet with name ...
  say "hello" joined with name
done

do greet with "John"

task add_numbers with a and b ...
  set result to a plus b
  give back result
done

set answer to run add_numbers with 10 and 5
say answer
